#!/usr/bin/env python3
"""
Throttle Test mit RevHeadz Input

Testet ob RevHeadz Throttle-Daten über TCP sendet und diese an RPM weitergeben.
"""

import socket
import logging

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")
logger = logging.getLogger("throttle-test")


def test_throttle_over_tcp():
    """Testet ob RevHeadz Throttle über TCP sendet."""
    
    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server.bind(("0.0.0.0", 2118))
    server.listen(1)
    
    logger.info("=" * 60)
    logger.info("Throttle Test Server auf Port 2118")
    logger.info("Verbinde RevHeadz mit: localhost:2118")
    logger.info("=" * 60)
    
    try:
        client, addr = server.accept()
        logger.info(f"Verbunden von {addr}")
        
        buffer = b""
        while True:
            data = client.recv(4096)
            if not data:
                break
            buffer += data
            text = data.decode('utf-8', errors='ignore')
            
            logger.info(f"Empfangen: {repr(text)}")
            
            # Auf Prompt warten
            if '> ' in text:
                # Antwort senden mit simulierten RPM
                import time
                rpm = 1200 + int(time.time() * 100) % 3000  # Simuierte RPM变化
                rpm_a = (rpm >> 8) & 0xFF
                rpm_b = rpm & 0xFF
                
                response = f"41 0C {rpm_a:02X} {rpm_b:02X}\r\n> "
                client.sendall(response.encode())
                logger.info(f"Antwort: RPM={rpm}")
                
    except KeyboardInterrupt:
        logger.info("Test gestoppt")
    finally:
        client.close()
        server.close()


if __name__ == "__main__":
    test_throttle_over_tcp()